<Window x:Class="GalaxySim.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galaxy Sim Launcher"
        Width="920"
        Height="660"
        MinWidth="860"
        MinHeight="600"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#05070D">

    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#080B14" Offset="0.0"/>
            <GradientStop Color="#0D1626" Offset="0.45"/>
            <GradientStop Color="#11162A" Offset="1.0"/>
        </LinearGradientBrush>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#DCE7FF"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F6F9FF"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#8090AA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid x:Name="RootShell" Margin="26" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform Y="16"/>
            </Grid.RenderTransform>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.35"/>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.35"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.12*"/>
                <ColumnDefinition Width="0.88*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,18">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="GALAXY SIM"
                           FontSize="36"
                           FontWeight="Bold"
                           Foreground="#EEF4FF"/>
                        <TextBlock x:Name="SubtitleText"
                           Text="Стартовые настройки сцены"
                           FontSize="14"
                           Foreground="#A8B7D4"
                           Margin="0,8,0,0"/>
                    </StackPanel>
                    <ComboBox x:Name="LanguageCombo"
                              DockPanel.Dock="Right"
                              Width="145"
                              HorizontalAlignment="Right"
                              SelectionChanged="LanguageCombo_SelectionChanged">
                        <ComboBoxItem Content="Русский"/>
                        <ComboBoxItem Content="English"/>
                    </ComboBox>
                </DockPanel>
            </StackPanel>

            <Border Grid.Row="1" Grid.Column="0"
                    Margin="0,0,14,0"
                    Background="#A0151D2C"
                    BorderBrush="#3B4C66"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ParticleLabelText" Grid.Row="0" Text="Количество звёзд" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="ParticlePresetCombo" Grid.Row="1" SelectionChanged="AnyCombo_SelectionChanged" DisplayMemberPath="Label"/>

                    <TextBlock x:Name="GalaxyLabelText" Grid.Row="2" Text="Тип галактики" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="GalaxyPresetCombo" Grid.Row="3" SelectionChanged="AnyCombo_SelectionChanged" DisplayMemberPath="Label"/>

                    <TextBlock x:Name="ResolutionLabelText" Grid.Row="4" Text="Разрешение рендера" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox x:Name="RenderResolutionCombo" Grid.Row="5" SelectionChanged="AnyCombo_SelectionChanged" DisplayMemberPath="Label"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1"
                    Background="#A0172133"
                    BorderBrush="#3F5272"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">
                <StackPanel>
                    <TextBlock x:Name="PreviewTitleText"
                               Text="Предпросмотр пресета"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#DCE7FF"/>

                    <Border Margin="0,12,0,0"
                            Background="#162033"
                            BorderBrush="#3D5478"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="PresetNameText"
                                       Text="—"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Foreground="#F4F8FF"/>
                            <TextBlock x:Name="PresetStarsText"
                                       Text="—"
                                       FontSize="13"
                                       FontFamily="Consolas"
                                       Foreground="#7FB2FF"
                                       Margin="0,8,0,0"/>
                            <TextBlock x:Name="PresetDescriptionText"
                                       Text="—"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Foreground="#AFC2E4"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0"
                            Background="#101728"
                            BorderBrush="#314666"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <TextBlock x:Name="TipText"
                                   Text="Совет: для 512K/1M начни с 1280x720 или 1600x900, затем повышай разрешение."
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="#93A8CB"/>
                    </Border>
                </StackPanel>
            </Border>

            <DockPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,18,0,0" LastChildFill="False">
                <Button x:Name="ExitButton"
                        Content="Выйти из приложения"
                        Width="190"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#232D40"
                        BorderBrush="#3B4E6A"
                        Foreground="#EAF0FF"
                        Click="Exit_Click"/>
                <Button x:Name="StartButton"
                        Content="Запустить"
                        Width="180"
                        Height="36"
                        Background="#2D4A7B"
                        BorderBrush="#5E8DD0"
                        Foreground="#F5F8FF"
                        FontWeight="SemiBold"
                        Click="Start_Click"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
