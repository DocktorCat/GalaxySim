<Window x:Class="GalaxySim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galaxy Sim"
        Width="1600" Height="960"
        MinWidth="1200" MinHeight="760"
        Background="#07090E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <LinearGradientBrush x:Key="BgMain" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#070A14" Offset="0"/>
            <GradientStop Color="#0D1524" Offset="0.55"/>
            <GradientStop Color="#101B2D" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="BgPanel" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#101722" Offset="0"/>
            <GradientStop Color="#0F1621" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="BgCard" Color="#1A2333"/>
        <SolidColorBrush x:Key="BgCardAlt" Color="#1D293A"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#33475F"/>
        <SolidColorBrush x:Key="TextMain" Color="#DCE7FF"/>
        <SolidColorBrush x:Key="TextDim" Color="#9AAFD0"/>
        <SolidColorBrush x:Key="Accent" Color="#78B5FF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#9CF8BF"/>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#000000"
                          ShadowDepth="0"
                          BlurRadius="12"
                          Opacity="0.28"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#EAF1FF"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="ValueBadgeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#98FFB8"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                                 To="-1.5"
                                                 Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,10"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F3F6FD"/>
            <Setter Property="Foreground" Value="#121212"/>
            <Setter Property="BorderBrush" Value="#8093B2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A3A53"/>
            <Setter Property="Foreground" Value="#F0F5FF"/>
            <Setter Property="BorderBrush" Value="#486A91"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#38567D"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.12"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#121B2A"/>
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#2E415A"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1A273A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#79B6FF"/>
                                <Setter Property="Foreground" Value="#F3F7FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F3F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootShell" Background="{StaticResource BgMain}" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform Y="12"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.30"/>
                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.30"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        
        <Border Grid.Column="0"
                Margin="14"
                Background="Black"
                BorderBrush="#2B3D53"
                BorderThickness="1"
                CornerRadius="12"
                ClipToBounds="True"
                MouseDown="Viewport_MouseDown"
                MouseMove="Viewport_MouseMove"
                MouseUp="Viewport_MouseUp"
                MouseWheel="Viewport_MouseWheel">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.32"/>
            </Border.Effect>
            <Grid>
                <Image x:Name="RenderImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="Linear"/>
                <Border HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="12"
                        Padding="10,6"
                        Background="#660A0D14"
                        CornerRadius="8">
                    <TextBlock Text="ЛКМ — орбита · колесо — зум"
                               FontSize="11"
                               Foreground="#B8C3D8"/>
                </Border>
            </Grid>
        </Border>

        
        <Border Grid.Column="1"
                Margin="0"
                Background="{StaticResource BgPanel}"
                BorderBrush="#2A3C52"
                BorderThickness="1,0,0,0">
            <DockPanel LastChildFill="True">

                
                <Border DockPanel.Dock="Top"
                        Background="#0D1219"
                        BorderBrush="#1D2532"
                        BorderThickness="0,0,0,1"
                        Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="GALAXY SIM"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#F2F6FF"/>
                        <TextBlock Text="N-body · HDR · Barnes–Hut"
                                   FontSize="11"
                                   Foreground="{StaticResource TextDim}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                
                <Border DockPanel.Dock="Top"
                        Background="#0C1117"
                        BorderBrush="#1D2532"
                        BorderThickness="0,0,0,1"
                        Padding="14,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FPS" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="FpsText"
                                       Grid.Column="1"
                                       Text="—"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#F1F5FF"/>
                        </Grid>
                        <TextBlock x:Name="TimingsText"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="{StaticResource AccentGreen}"
                                   TextWrapping="Wrap"
                                   Text="[waiting]"/>
                    </StackPanel>
                </Border>

                
                <TabControl Margin="0" Background="{StaticResource BgPanel}">

                    
                    <TabItem Header="Сцена">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                            <StackPanel>

                                
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ТИП ГАЛАКТИКИ" Style="{StaticResource SectionTitleStyle}"/>
                                        <TextBlock Text="Предустановка" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox x:Name="PresetCombo"
                                                  SelectionChanged="Preset_Changed">
                                            <ComboBoxItem Content="Млечный Путь" IsSelected="True"/>
                                            <ComboBoxItem Content="Андромеда (M31)"/>
                                            <ComboBoxItem Content="NGC 1300 (барная)"/>
                                            <ComboBoxItem Content="M74 Вертушка"/>
                                            <ComboBoxItem Content="Карликовая галактика"/>
                                        </ComboBox>
                                        <TextBlock x:Name="PresetDescription"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDim}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="Спиральная галактика, умеренный halo, яркое ядро"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="SelectedStarCard"
                                        Style="{StaticResource CardBorderStyle}"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="ВЫБРАННАЯ ЗВЕЗДА" Style="{StaticResource SectionTitleStyle}"/>
                                        <Grid Margin="0,2,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="82"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="68"
                                                    Height="68"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#111827"
                                                    BorderBrush="#52677F"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    ClipToBounds="True">
                                                <Viewport3D x:Name="SelectedStarViewport"
                                                            IsHitTestVisible="False">
                                                    <Viewport3D.Camera>
                                                        <PerspectiveCamera x:Name="SelectedStarCamera"
                                                                           Position="0,0,4"
                                                                           LookDirection="0,0,-4"
                                                                           UpDirection="0,1,0"
                                                                           FieldOfView="34"/>
                                                    </Viewport3D.Camera>
                                                    <ModelVisual3D>
                                                        <ModelVisual3D.Content>
                                                            <Model3DGroup x:Name="SelectedStarScene"/>
                                                        </ModelVisual3D.Content>
                                                    </ModelVisual3D>
                                                </Viewport3D>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="SelectedStarNameText"
                                                           Text="—"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock x:Name="SelectedStarTypeText"
                                                           Text="—"
                                                           Foreground="{StaticResource TextDim}"
                                                           Margin="0,4,0,0"/>
                                                <TextBlock x:Name="SelectedStarModelText"
                                                           Text="Модель: —"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AccentGreen}"
                                                           Margin="0,5,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Button Content="Открыть модель"
                                                            Padding="8,4"
                                                            Click="OpenSelectedStarModel_Click"/>
                                                    <Button Content="Система"
                                                            Margin="8,0,0,0"
                                                            Padding="8,4"
                                                            Click="OpenSelectedSystem_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock x:Name="SelectedStarDetailsText"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   Foreground="{StaticResource TextDim}"
                                                   TextWrapping="Wrap"
                                                   Text=""/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    
                    <TabItem Header="Физика">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                            <StackPanel>
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ПАРАМЕТРЫ" Style="{StaticResource SectionTitleStyle}"/>

                                        <Grid>
                                            <TextBlock Text="Масштаб времени" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=TimeScaleSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="TimeScaleSlider"
                                                Minimum="0" Maximum="3" Value="1"
                                                ValueChanged="TimeScale_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Гравитация" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=GravitySlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="GravitySlider"
                                                Minimum="0.05" Maximum="2.0" Value="0.5"
                                                ValueChanged="Gravity_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Смягчение" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=SofteningSlider, Path=Value, StringFormat={}{0:F3}}"/>
                                        </Grid>
                                        <Slider x:Name="SofteningSlider"
                                                Minimum="0.01" Maximum="0.5" Value="0.08"
                                                ValueChanged="Softening_Changed"/>

                                        <Grid>
                                            <TextBlock Text="BH accuracy (θ)" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=ThetaSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="ThetaSlider"
                                                Minimum="0.4" Maximum="1.5" Value="0.8"
                                                ValueChanged="Theta_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Скорость гало v₀" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=HaloV0Slider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="HaloV0Slider"
                                                Minimum="0.2" Maximum="2.5" Value="1.4"
                                                ValueChanged="HaloV0_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Радиус ядра Rc" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=HaloRcSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="HaloRcSlider"
                                                Minimum="0.5" Maximum="8.0" Value="1.5"
                                                ValueChanged="HaloRc_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Масса СМЧД" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BhMassSlider, Path=Value, StringFormat={}{0:F1}}"/>
                                        </Grid>
                                        <Slider x:Name="BhMassSlider"
                                                Minimum="0" Maximum="30" Value="4"
                                                ValueChanged="BhMass_Changed"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    
                    <TabItem Header="Визуал">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                            <StackPanel>

                                
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="РЕНДЕР" Style="{StaticResource SectionTitleStyle}"/>

                                        <Grid>
                                            <TextBlock Text="Экспозиция" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=ExposureSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="ExposureSlider"
                                                Minimum="0.1" Maximum="4.0" Value="1.2"
                                                ValueChanged="Exposure_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Размер сплата" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=SplatSlider, Path=Value, StringFormat={}{0:F0}}"/>
                                        </Grid>
                                        <Slider x:Name="SplatSlider"
                                                Minimum="1" Maximum="200" Value="55"
                                                ValueChanged="Splat_Changed"/>
                                    </StackPanel>
                                </Border>

                                
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="BLOOM" Style="{StaticResource SectionTitleStyle}"/>

                                        <Grid>
                                            <TextBlock Text="Порог" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BloomThresholdSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="BloomThresholdSlider"
                                                Minimum="0.1" Maximum="3.0" Value="0.8"
                                                ValueChanged="BloomThreshold_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Интенсивность" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BloomIntensitySlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="BloomIntensitySlider"
                                                Minimum="0" Maximum="2.0" Value="0.7"
                                                ValueChanged="BloomIntensity_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Локальный контраст" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=LocalContrastSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="LocalContrastSlider"
                                                Minimum="0" Maximum="1.2" Value="0.34"
                                                ValueChanged="LocalContrast_Changed"/>
                                    </StackPanel>
                                </Border>

                                
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ТКАНЬ ГАЛАКТИКИ" Style="{StaticResource SectionTitleStyle}"/>
                                        <CheckBox x:Name="DiffuseCheck" Content="Включить"
                                                  IsChecked="True"
                                                  Checked="Diffuse_Toggle"
                                                  Unchecked="Diffuse_Toggle"
                                                  Foreground="{StaticResource TextMain}"
                                                  Margin="0,0,0,8"/>

                                        <Grid>
                                            <TextBlock Text="Плотность свечения" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=DiffuseIntensitySlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="DiffuseIntensitySlider"
                                                Minimum="0" Maximum="0.5" Value="0.15"
                                                ValueChanged="DiffuseIntensity_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Радиус свечения" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=DiffuseRadiusSlider, Path=Value, StringFormat={}{0:F0}}"/>
                                        </Grid>
                                        <Slider x:Name="DiffuseRadiusSlider"
                                                Minimum="4" Maximum="25" Value="12"
                                                ValueChanged="DiffuseRadius_Changed"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="UNRESOLVED STARLIGHT" Style="{StaticResource SectionTitleStyle}"/>
                                        <CheckBox x:Name="UnresolvedCheck" Content="Включить"
                                                  IsChecked="True"
                                                  Checked="Unresolved_Toggle"
                                                  Unchecked="Unresolved_Toggle"
                                                  Foreground="{StaticResource TextMain}"
                                                  Margin="0,0,0,8"/>

                                        <Grid>
                                            <TextBlock Text="Интенсивность слоя" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=UnresolvedIntensitySlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="UnresolvedIntensitySlider"
                                                Minimum="0" Maximum="3.2" Value="1.55"
                                                ValueChanged="UnresolvedIntensity_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Подавление blob-артефактов звёзд" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BlobSuppressionSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="BlobSuppressionSlider"
                                                Minimum="0" Maximum="1.25" Value="0.72"
                                                ValueChanged="BlobSuppression_Changed"/>
                                    </StackPanel>
                                </Border>

                                
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="HII ТУМАННОСТИ" Style="{StaticResource SectionTitleStyle}"/>
                                        <CheckBox x:Name="NebulaeCheck" Content="Включить"
                                                  IsChecked="True"
                                                  Checked="Nebulae_Toggle"
                                                  Unchecked="Nebulae_Toggle"
                                                  Foreground="{StaticResource TextMain}"
                                                  Margin="0,0,0,8"/>

                                        <Grid>
                                            <TextBlock Text="Яркость" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=NebulaIntensitySlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="NebulaIntensitySlider"
                                                Minimum="0" Maximum="0.4" Value="0.12"
                                                ValueChanged="NebulaIntensity_Changed"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="BH LENSING" Style="{StaticResource SectionTitleStyle}"/>
                                        <CheckBox x:Name="BhLensingCheck" Content="Включить"
                                                  IsChecked="True"
                                                  Checked="BhLensing_Toggle"
                                                  Unchecked="BhLensing_Toggle"
                                                  Foreground="{StaticResource TextMain}"
                                                  Margin="0,0,0,8"/>

                                        <Grid>
                                            <TextBlock Text="Сила искажения" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BhLensingStrengthSlider, Path=Value, StringFormat={}{0:F4}}"/>
                                        </Grid>
                                        <Slider x:Name="BhLensingStrengthSlider"
                                                Minimum="0" Maximum="0.02" Value="0.0026"
                                                ValueChanged="BhLensingStrength_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Дистанция начала" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BhLensingNearSlider, Path=Value, StringFormat={}{0:F1}}"/>
                                        </Grid>
                                        <Slider x:Name="BhLensingNearSlider"
                                                Minimum="0.2" Maximum="5.0" Value="0.85"
                                                ValueChanged="BhLensingNear_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Дистанция конца" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BhLensingFarSlider, Path=Value, StringFormat={}{0:F1}}"/>
                                        </Grid>
                                        <Slider x:Name="BhLensingFarSlider"
                                                Minimum="0.4" Maximum="8.0" Value="1.75"
                                                ValueChanged="BhLensingFar_Changed"/>
                                    </StackPanel>
                                </Border>

                                
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ПЫЛЬ" Style="{StaticResource SectionTitleStyle}"/>
                                        <CheckBox x:Name="CoherentDustCheck" Content="Согласованные пылевые рукава"
                                                  IsChecked="True"
                                                  Checked="CoherentDust_Toggle"
                                                  Unchecked="CoherentDust_Toggle"
                                                  Foreground="{StaticResource TextMain}"
                                                  Margin="0,0,0,8"/>

                                        <Grid>
                                            <TextBlock Text="Сила рукавов" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=CoherentDustStrengthSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="CoherentDustStrengthSlider"
                                                Minimum="0" Maximum="4.0" Value="1.80"
                                                ValueChanged="CoherentDustStrength_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Спиралевидность тела" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BodySpiralnessSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="BodySpiralnessSlider"
                                                Minimum="0" Maximum="1.0" Value="0.72"
                                                ValueChanged="BodySpiralness_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Градиент тела" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=BodyGradientSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="BodyGradientSlider"
                                                Minimum="0" Maximum="1.0" Value="0.86"
                                                ValueChanged="BodyGradient_Changed"/>

                                        <TextBlock Text="Цвет тела" Style="{StaticResource LabelStyle}"/>
                                        <ComboBox x:Name="BodyColorThemeCombo"
                                                  SelectionChanged="BodyColorTheme_Changed">
                                            <ComboBoxItem Content="Тёплый янтарный" IsSelected="True"/>
                                            <ComboBoxItem Content="Золото + синий ореол"/>
                                            <ComboBoxItem Content="Розовый + холодный ореол"/>
                                            <ComboBoxItem Content="Холодный голубой"/>
                                        </ComboBox>

                                        <Grid>
                                            <TextBlock Text="Непрозрачность" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=DustSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="DustSlider"
                                                Minimum="0" Maximum="3.0" Value="1.0"
                                                ValueChanged="Dust_Changed"/>

                                        <Grid>
                                            <TextBlock Text="Подавление blob-артефактов пыли" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock Style="{StaticResource ValueBadgeStyle}"
                                                       Text="{Binding ElementName=DustBlobSuppressionSlider, Path=Value, StringFormat={}{0:F2}}"/>
                                        </Grid>
                                        <Slider x:Name="DustBlobSuppressionSlider"
                                                Minimum="0" Maximum="1.5" Value="0.78"
                                                ValueChanged="DustBlobSuppression_Changed"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    
                    <TabItem Header="Действия">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                            <StackPanel>

                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="СИМУЛЯЦИЯ" Style="{StaticResource SectionTitleStyle}"/>
                                        <WrapPanel>
                                            <Button x:Name="PauseBtn"
                                                    Content="Пауза"
                                                    Width="92"
                                                    Click="Pause_Click"/>
                                            <Button Content="Сброс"
                                                    Width="92"
                                                    Click="Reset_Click"/>
                                            <Button Content="В меню"
                                                    Width="92"
                                                    Click="BackToMenu_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ЭКСПОРТ" Style="{StaticResource SectionTitleStyle}"/>
                                        <Button Content="Сохранить скриншот"
                                                Width="170"
                                                Click="Screenshot_Click"
                                                Margin="0,0,0,8"/>
                                        <TextBlock x:Name="ScreenshotStatus"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextDim}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   Text=""/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="ДИАГНОСТИКА" Style="{StaticResource SectionTitleStyle}"/>
                                        <Button Content="Проверить BVH"
                                                Width="140"
                                                Click="VerifyHistogram_Click"
                                                Margin="0,0,0,8"/>
                                        <TextBlock x:Name="VerifyText"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextDim}"
                                                   Text="Проверка BVH: не запускалась"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
