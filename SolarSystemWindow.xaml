<Window x:Class="GalaxySim.SolarSystemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Звёздная система"
        Width="940"
        Height="560"
        MinWidth="780"
        MinHeight="460"
        Background="#07090E"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#111827"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#33475F"/>
        <SolidColorBrush x:Key="TextMain" Color="#DCE7FF"/>
        <SolidColorBrush x:Key="TextDim" Color="#9AAFD0"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#9CF8BF"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="390"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,12">
            <TextBlock x:Name="SystemNameText"
                       Foreground="{StaticResource TextMain}"
                       FontSize="22"
                       FontWeight="SemiBold"/>
            <TextBlock x:Name="SystemTypeText"
                       Foreground="{StaticResource TextDim}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,14,0"
                Background="#05070B"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="8"
                ClipToBounds="True"
                MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
                MouseMove="Viewport_MouseMove"
                MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
                MouseWheel="Viewport_MouseWheel">
            <Image x:Name="SystemRenderImage"
                   Stretch="Uniform"
                   SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="ParamsTitleText"
                               Text="ПАРАМЕТРЫ"
                               Foreground="{StaticResource TextMain}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <TextBlock x:Name="ZoomLabelText"
                               Text="Масштаб"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"/>
                    <Slider x:Name="ZoomSlider"
                            Minimum="0.08"
                            Maximum="12"
                            Value="1"
                            TickFrequency="0.05"
                            ValueChanged="ViewControl_Changed"/>

                    <TextBlock x:Name="SpeedLabelText"
                               Text="Скорость анимаций"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"
                               Margin="0,10,0,0"/>
                    <Slider x:Name="SpeedSlider"
                            Minimum="0"
                            Maximum="4"
                            Value="1"
                            TickFrequency="0.1"
                            ValueChanged="ViewControl_Changed"/>

                    <TextBlock x:Name="QualityLabelText"
                               Text="Качество"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"
                               Margin="0,10,0,0"/>
                    <ComboBox x:Name="QualityCombo"
                              SelectedIndex="1"
                              SelectionChanged="QualityCombo_SelectionChanged">
                        <ComboBoxItem x:Name="QualityFastItem" Content="Быстро"/>
                        <ComboBoxItem x:Name="QualityBalancedItem" Content="Баланс"/>
                        <ComboBoxItem x:Name="QualityHighItem" Content="Высокое"/>
                        <ComboBoxItem x:Name="QualityUltraItem" Content="Ультра 2K"/>
                    </ComboBox>

                    <CheckBox x:Name="Mode3DCheck"
                              Content="3D режим"
                              Foreground="{StaticResource TextMain}"
                              Margin="0,12,0,0"
                              Checked="ViewMode_Changed"
                              Unchecked="ViewMode_Changed"/>

                    <CheckBox x:Name="RealismCheck"
                              Content="Реализм масштаба"
                              Foreground="{StaticResource TextMain}"
                              Margin="0,8,0,0"
                              Checked="ViewMode_Changed"
                              Unchecked="ViewMode_Changed"/>

                    <TextBlock x:Name="YawLabelText"
                               Text="Поворот"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"
                               Margin="0,10,0,0"/>
                    <Slider x:Name="YawSlider"
                            Minimum="-180"
                            Maximum="180"
                            Value="25"
                            TickFrequency="1"
                            ValueChanged="ViewControl_Changed"/>

                    <TextBlock x:Name="PitchLabelText"
                               Text="Наклон"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"
                               Margin="0,10,0,0"/>
                    <Slider x:Name="PitchSlider"
                            Minimum="0"
                            Maximum="78"
                            Value="58"
                            TickFrequency="1"
                            ValueChanged="ViewControl_Changed"/>

                    <UniformGrid Columns="2" Margin="0,12,0,0">
                        <Button x:Name="FocusStarButton"
                                Content="К звезде"
                                Margin="0,0,4,0"
                                Padding="8,5"
                                Click="FocusStar_Click"/>
                        <Button x:Name="FocusSelectedButton"
                                Content="К выбору"
                                Margin="4,0,0,0"
                                Padding="8,5"
                                Click="FocusSelected_Click"/>
                    </UniformGrid>

                    <Button x:Name="ResetViewButton"
                            Content="Сбросить вид"
                            Margin="0,12,0,16"
                            Padding="8,5"
                            Click="ResetView_Click"/>

                    <TextBlock x:Name="SystemDetailsText"
                               Foreground="{StaticResource TextDim}"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="ObjectsTitleText"
                               Text="ОБЪЕКТЫ"
                               Foreground="{StaticResource TextMain}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,14,0,8"/>
                    <ListBox x:Name="ObjectList"
                             MinHeight="120"
                             MaxHeight="210"
                             Background="#0C1322"
                             BorderBrush="{StaticResource BorderSoft}"
                             Foreground="{StaticResource TextMain}"
                             SelectionChanged="ObjectList_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           FontFamily="Consolas"
                                           FontSize="12"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border x:Name="PlanetCard"
                            Visibility="Collapsed"
                            BorderBrush="{StaticResource BorderSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,14,0,0"
                            Background="#172033">
                        <StackPanel>
                            <TextBlock x:Name="PlanetNameText"
                                       Foreground="{StaticResource TextMain}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="PlanetTypeText"
                                       Foreground="{StaticResource AccentGreen}"
                                       FontSize="12"
                                       Margin="0,4,0,0"/>
                            <TextBlock x:Name="PlanetDetailsText"
                                       Foreground="{StaticResource TextDim}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                            <TextBlock x:Name="PlanetDescriptionText"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <TextBlock x:Name="PausedStatusText"
                   Grid.Row="2"
                   Grid.Column="0"
                   Foreground="{StaticResource AccentGreen}"
                   Margin="0,12,0,0"
                   Text="Симуляция приостановлена"/>

        <Button x:Name="CloseButton"
                Grid.Row="2"
                Grid.Column="1"
                Content="Закрыть"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Padding="16,6"
                Click="Close_Click"/>
    </Grid>
</Window>
